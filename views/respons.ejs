<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Trip Planner - Plan Your Perfect Journey</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
            min-height: 100vh;
            animation: gradientShift 15s ease infinite;
            background-size: 200% 200%;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Navbar Styles */
        header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 20px 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
            animation: slideDown 0.5s ease;
        }

        @keyframes slideDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        header h1 {
            color: #2d3748;
            font-size: 1.8em;
            background: linear-gradient(135deg, #38b2ac 0%, #2c7a7b 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: fadeIn 0.8s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        nav {
            display: flex;
            align-items: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .nav-links {
            display: flex;
            gap: 20px;
        }

        nav a {
            color: #2d3748;
            text-decoration: none;
            font-weight: 600;
            font-size: 1em;
            padding: 8px 15px;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #38b2ac, #2c7a7b);
            transform: translateX(-50%);
            transition: width 0.3s ease;
        }

        nav a:hover {
            color: #38b2ac;
            transform: translateY(-2px);
        }

        nav a:hover::after {
            width: 80%;
        }

        /* Auth Buttons */
        .auth-buttons {
            display: flex;
            gap: 10px;
        }

        .login-btn {
            padding: 10px 25px !important;
            background: white;
            color: #38b2ac !important;
            border: 2px solid #38b2ac;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .login-btn::after {
            display: none !important;
        }

        .login-btn:hover {
            background: #e6fffa;
            transform: translateY(-3px) !important;
            box-shadow: 0 5px 15px rgba(56, 178, 172, 0.2);
            color: #2c7a7b !important;
        }

        .signup-btn {
            padding: 10px 25px !important;
            background: linear-gradient(135deg, #38b2ac 0%, #2c7a7b 100%);
            color: white !important;
            border: 2px solid transparent;
            border-radius: 25px;
            font-weight: 600;
            box-shadow: 0 5px 15px rgba(56, 178, 172, 0.3);
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .signup-btn::after {
            display: none !important;
        }

        .signup-btn:hover {
            transform: translateY(-3px) !important;
            box-shadow: 0 8px 20px rgba(56, 178, 172, 0.5);
        }

        hr {
            display: none;
        }

        /* Hero Section */
        .hero {
            max-width: 1200px;
            margin: 60px auto;
            padding: 80px 20px;
            text-align: center;
            animation: fadeInUp 0.8s ease 0.2s backwards;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero h2 {
            font-size: 3.5em;
            color: #2d3748;
            margin-bottom: 20px;
            line-height: 1.2;
            animation: fadeInUp 0.8s ease 0.3s backwards;
        }

        .hero p {
            font-size: 1.4em;
            color: #4a5568;
            margin-bottom: 40px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 0.8s ease 0.4s backwards;
        }

        .hero-btn {
            display: inline-block;
            padding: 18px 50px;
            background: linear-gradient(135deg, #38b2ac 0%, #2c7a7b 100%);
            color: white;
            text-decoration: none;
            font-size: 1.2em;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 10px 30px rgba(56, 178, 172, 0.3);
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.8s ease 0.5s backwards;
        }

        .hero-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .hero-btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(56, 178, 172, 0.5);
        }

        .hero-btn:hover::before {
            width: 500px;
            height: 500px;
        }

        /* Trip Form Section */
        .form-section {
            max-width: 800px;
            margin: 60px auto;
            padding: 20px;
            animation: fadeInUp 0.8s ease 0.6s backwards;
        }

        .form-container {
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            position: relative;
            overflow: hidden;
        }

        .form-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #38b2ac, #2c7a7b);
            animation: shimmer 2s ease infinite;
        }

        @keyframes shimmer {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .form-section h2 {
            text-align: center;
            color: #2d3748;
            font-size: 2.5em;
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #2d3748;
            font-weight: 600;
            font-size: 1em;
        }

        input[type="text"],
        input[type="number"],
        select {
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1em;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        input[type="text"]:hover,
        input[type="number"]:hover,
        select:hover {
            border-color: #81e6d9;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(56, 178, 172, 0.15);
        }

        input[type="text"]:focus,
        input[type="number"]:focus,
        select:focus {
            outline: none;
            border-color: #38b2ac;
            box-shadow: 0 0 0 4px rgba(56, 178, 172, 0.15), 0 5px 15px rgba(56, 178, 172, 0.2);
            transform: translateY(-2px);
        }

        /* Checkbox Group */
        .checkbox-group {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 10px;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: white;
        }

        .checkbox-item:hover {
            border-color: #38b2ac;
            background: #e6fffa;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(56, 178, 172, 0.15);
        }

        .checkbox-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #38b2ac;
        }

        .checkbox-item label {
            margin: 0;
            cursor: pointer;
            font-weight: 500;
        }

        /* Submit Button */
        .submit-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #38b2ac 0%, #2c7a7b 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1.2em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            position: relative;
            overflow: hidden;
            background-size: 200% 200%;
            animation: gradientMove 3s ease infinite;
            margin-top: 20px;
        }

        @keyframes gradientMove {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .submit-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .submit-btn:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 40px rgba(56, 178, 172, 0.5);
        }

        .submit-btn:hover::before {
            width: 600px;
            height: 600px;
        }

        .submit-btn:active {
            transform: translateY(-2px) scale(0.98);
        }

        /* Footer */
        footer {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 30px 20px;
            text-align: center;
            margin-top: 80px;
            box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
        }

        footer p {
            color: #4a5568;
            font-size: 1em;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .nav-container {
                flex-direction: column;
                text-align: center;
            }

            header h1 {
                font-size: 1.5em;
            }

            .nav-links {
                flex-direction: column;
                gap: 10px;
            }

            .auth-buttons {
                width: 100%;
                justify-content: center;
            }

            .hero h2 {
                font-size: 2.5em;
            }

            .hero p {
                font-size: 1.2em;
            }

            .form-container {
                padding: 30px 20px;
            }

            .checkbox-group {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 480px) {
            .hero h2 {
                font-size: 2em;
            }
        }

        /* Emoji Animation */
        .emoji {
            display: inline-block;
            animation: wave 1.5s ease infinite;
        }

        @keyframes wave {
            0%, 100% { transform: rotate(0deg); }
            25% { transform: rotate(-15deg); }
            75% { transform: rotate(15deg); }
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <!-- <header>
        <div class="nav-container">
            <h1><span class="emoji">✈️</span> AI Trip Planner</h1>
            <nav>
                <div class="nav-links">
                    <a href="/">Home</a>
                    <a href="#tripForm">Plan Trip</a>
                    <a href="/about">About</a>
                </div>
                <div class="auth-buttons">
                    <a href="/user/login" class="login-btn">Login</a>
                    <a href="/register" class="signup-btn">Sign Up</a>  
                </div>
            </nav>
        </div>
    </header> -->
    <%- include("partial/nav") %>
    <!-- Hero Section -->
    <section class="hero">
        <h2>Plan Your Perfect Trip with AI <span class="emoji">🌍</span></h2>
        <p>Enter your travel details and let AI generate the best itinerary for you. Discover amazing destinations, local experiences, and create unforgettable memories!</p>
        <a href="#tripForm" class="hero-btn">Start Planning <span class="emoji">🚀</span></a>
    </section>

    <!-- Trip Form Section -->
    <section class="form-section" id="tripForm">
        <div class="form-container">
            <h2>Plan Your Trip <span class="emoji">📝</span></h2>
            <form action="/generate-trip" method="POST">
                <div class="form-group">
                    <label for="destination">Destination:</label>
                    <input type="text" id="destination" name="destination" placeholder="e.g., Paris, Goa, Tokyo" required>
                </div>

                <div class="form-group">
                    <label for="budget">Budget (in ₹):</label>
                    <input type="number" id="budget" name="budget" placeholder="e.g., 50000" required>
                </div>

                <div class="form-group">
                    <label for="days">Number of Days:</label>
                    <input type="number" id="days" name="days" placeholder="e.g., 7" min="1" max="30" required>
                </div>

                <div class="form-group">
                    <label for="travelType">Travel Type:</label>
                    <select id="travelType" name="travelType" required>
                        <option value="">-- Select Travel Type --</option>
                        <option value="solo">🧳 Solo</option>
                        <option value="family">👨‍👩‍👧‍👦 Family</option>
                        <option value="friends">👥 Friends</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Interests:</label>
                    <div class="checkbox-group">
                        <div class="checkbox-item">
                            <input type="checkbox" id="adventure" name="interests" value="adventure">
                            <label for="adventure">🏔️ Adventure</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="nature" name="interests" value="nature">
                            <label for="nature">🌳 Nature</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="food" name="interests" value="food">
                            <label for="food">🍽️ Food</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="religious" name="interests" value="religious">
                            <label for="religious">🕉️ Religious</label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="submit-btn">
                    Generate Trip Plan ✨
                </button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 AI Trip Planner | Built with <span style="color: #e53e3e;">❤️</span> by Rajneesh</p>
    </footer>

    <script>
        // Smooth scroll to form
        document.querySelector('.hero-btn').addEventListener('click', function(e) {
            e.preventDefault();
            document.querySelector('#tripForm').scrollIntoView({ 
                behavior: 'smooth',
                block: 'start'
            });
        });

        // Add ripple effect on button click
        document.querySelector('.submit-btn').addEventListener('click', function(e) {
            const ripple = document.createElement('span');
            const rect = this.getBoundingClientRect();
            ripple.style.position = 'absolute';
            ripple.style.width = ripple.style.height = '100px';
            ripple.style.borderRadius = '50%';
            ripple.style.background = 'rgba(255,255,255,0.6)';
            ripple.style.left = e.clientX - rect.left - 50 + 'px';
            ripple.style.top = e.clientY - rect.top - 50 + 'px';
            ripple.style.pointerEvents = 'none';
            ripple.style.animation = 'ripple 0.6s ease';
            this.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
        });

        // Ripple animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes ripple {
                from {
                    transform: scale(0);
                    opacity: 1;
                }
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);

        // Checkbox item click enhancement
        document.querySelectorAll('.checkbox-item').forEach(item => {
            item.addEventListener('click', function(e) {
                if (e.target.tagName !== 'INPUT') {
                    const checkbox = this.querySelector('input[type="checkbox"]');
                    checkbox.checked = !checkbox.checked;
                }
            });
        });
    </script>
</body>
</html>